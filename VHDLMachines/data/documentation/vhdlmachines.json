atement"}],"role":"symbol","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/AfterStatement","abstract":[{"type":"text","text":"An after statement found commonly on "},{"type":"codeVoice","code":"LLFSM"},{"type":"text","text":" transitions. The after statements represents a boolean"},{"type":"text","text":" "},{"type":"text","text":"condition that evaluates to "},{"type":"codeVoice","code":"true"},{"type":"text","text":" when a specified amount of time has elapsed. The supported after"},{"type":"text","text":" "},{"type":"text","text":"statements for "},{"type":"codeVoice","code":"VHDL"},{"type":"text","text":" machines are: "},{"type":"codeVoice","code":"after"},{"type":"text","text":" (seconds), "},{"type":"codeVoice","code":"after_ms"},{"type":"text","text":" (milliseconds), "},{"type":"codeVoice","code":"after_us"},{"type":"text","text":" "},{"type":"text","text":"(microseconds), "},{"type":"codeVoice","code":"after_ns"},{"type":"text","text":" (nanoseconds), "},{"type":"codeVoice","code":"after_ps"},{"type":"text","text":" (picoseconds) and "},{"type":"codeVoice","code":"after_rt"},{"type":"text","text":" (ringlets)."}],"type":"topic","title":"AfterStatement","kind":"symbol","url":"\/documentation\/vhdlmachines\/afterstatement","navigatorTitle":[{"kind":"identifier","text":"AfterStatement"}]},"doc://VHDLMachines/documentation/VHDLMachines/MachineMapping":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MachineMapping"}],"abstract":[{"text":"A machine mapping is a mapping of variables to the external interface of the machine. The variables","type":"text"},{"text":" ","type":"text"},{"text":"must be either clocks, external signals, parameters or return variables.","type":"text"}],"type":"topic","title":"MachineMapping","url":"\/documentation\/vhdlmachines\/machinemapping","role":"symbol","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/MachineMapping","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","tex