 and FPGAs"}]},{"type":"text","text":" published at ReConfig2018. This format does not contain"},{"type":"text","text":" "},{"type":"text","text":"any inherent fault tolerance, but does provide mechanisms for after statements, suspension and"},{"type":"text","text":" "},{"type":"text","text":"parameterisation. Snapshot semantics are present for both external variables and parameters."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MachineRepresentation"}],"type":"topic"},"doc://VHDLMachines/documentation/VHDLMachines/ArrangementVHDLRepresentable":{"title":"ArrangementVHDLRepresentable","abstract":[{"text":"An arrangement representation in ","type":"text"},{"type":"codeVoice","code":"VHDL"},{"text":". This type allows multiple representations to be created by","type":"text"},{"text":" ","type":"text"},{"text":"conforming to this protocol.","type":"text"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/ArrangementVHDLRepresentable","url":"\/documentation\/vhdlmachines\/arrangementvhdlrepresentable","navigatorTitle":[{"text":"ArrangementVHDLRepresentable","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ArrangementVHDLRepresentable","kind":"identifier"}],"type":"topic"},"doc://VHDLMachines/documentation/VHDLMachines/ActionName":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"ActionName"}],"title":"ActionName","url":"\/documentation\/vhdlmachines\/actionname","abstract":[{"type":"text","text":"The type of a machine’s action."}],"kind":"symbol","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/ActionName","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"ActionName"}],"role":"symbol"}}}