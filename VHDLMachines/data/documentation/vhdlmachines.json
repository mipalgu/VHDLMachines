 "},{"type":"codeVoice","code":"VHDL"},{"type":"text","text":" representation. This structure is similar to the "},{"type":"codeVoice","code":"VHDL"},{"type":"text","text":" "},{"type":"text","text":"representation from my honours paper "},{"type":"emphasis","inlineContent":[{"type":"text","text":"High-level Executable Models of Reactive Real-Time Systems with"},{"type":"text","text":" "},{"type":"text","text":"Logic-Labelled Finite-State Machines and FPGAs"}]},{"type":"text","text":" published at ReConfig2018. This format does not contain"},{"type":"text","text":" "},{"type":"text","text":"any inherent fault tolerance, but does provide mechanisms for after statements, suspension and"},{"type":"text","text":" "},{"type":"text","text":"parameterisation. Snapshot semantics are present for both external variables and parameters."}],"title":"MachineRepresentation"},"doc://VHDLMachines/documentation/VHDLMachines/Machine":{"url":"\/documentation\/vhdlmachines\/machine","type":"topic","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/Machine","abstract":[{"type":"text","text":"The VHDL implementation of an LLFSM."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Machine"}],"role":"symbol","kind":"symbol","title":"Machine","navigatorTitle":[{"kind":"identifier","text":"Machine"}]},"doc://VHDLMachines/documentation/VHDLMachines/MachineName":{"title":"MachineName","abstract":[{"text":"The type of a machine’s name.","type":"text"}],"identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/MachineName","type":"topic","role":"symbol","url":"\/documentation\/vhdlmachines\/machinename","kind":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MachineName","kind":"identifier"}],"navigatorTitle":[{"text":"MachineName","kind":"identifier"}]},"doc://VHDLMachines/documentation/VHDLMachines/VHDLCompiler":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"tex