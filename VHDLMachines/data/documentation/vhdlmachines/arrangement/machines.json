s":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"machines"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","preciseIdentifier":"s:12VHDLMachines15MachineInstanceV","text":"MachineInstance"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:12VHDLMachines14MachineMappingV","text":"MachineMapping"},{"kind":"text","text":"]"}],"abstract":[{"type":"text","text":"All machines in the arrangement."}],"kind":"symbol","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/Arrangement\/machines","url":"\/documentation\/vhdlmachines\/arrangement\/machines","type":"topic"},"doc://VHDLMachines/documentation/VHDLMachines/MachineInstance":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MachineInstance"}],"role":"symbol","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/MachineInstance","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"MachineInstance"},{"type":"text","text":" represents an instance of a machine that lives within an arrangement. The "},{"type":"codeVoice","code":"name"},{"type":"text","text":" of"},{"type":"text","text":" "},{"type":"text","text":"the instance should be unique to any other instance of the same machine. The "},{"type":"codeVoice","code":"type"},{"type":"text","text":" property is the type"},{"type":"text","text":" "},{"type":"text","text":"of the machine, typically derived from a shared path where the machine is located."}],"type":"topic","title":"MachineInstance","kind":"symbol","url":"\/documentation\/vhdlmachines\/machineinstance","navigatorTitle":[{"kind":"identifier","text":"MachineInstance"}]},"doc://VHDLMachines/documentation/VHDLMachines":{"role":"collection","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines","abstract":[],"type":"topic","title":"VHDLMachines","kind":"symbol","url":"\/documentation\/vhdlmachines"},"doc://VHDLMachines/documentation/VHDLMachines/Arrangement":{"abstract":[{"text":"An arrangement represents a collection of machines that are executing together. An arrangment has a set of","type":"text"},{"text":" ","type":"text"},{"text":"parent machines which act as entry points into the program. This structure does not infer any execution","type":"text"},{"text":" ","type":"text"},{"text":"order for the machines in this arrangement. Instead, this arrangement simply defines the machines and the","type":"text"},{"text":" ","type":"text"},{"text":"capability of each machine (Suspensible, Parameterised, Custom Ringlets etc).","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/vhdlmachines\/arrangement","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/Arrangement","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Arrangement"}],"navigatorTitle":[{"kind":"identifier","text":"Arrangement"}],"role":"symbol","title":"Arrangement"},"doc://VHDLMachines/documentation/VHDLMachines/MachineMapping":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MachineMapping"}],"abstract":[{"text":"A machine mapping is a mapping of variables to the external interface of the machine. The variables","type":"text"},{"text":" ","type":"text"},{"text":"must be either clocks, external signals, parameters or return variables.","type":"text"}],"type":"topic","title":"MachineMapping","url":"\/documentation\/vhdlmachines\/machinemapping","role":"symbol","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/MachineMapping","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MachineMapping"}]}}}