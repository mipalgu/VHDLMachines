:"doc:\/\/VHDLMachines\/documentation\/VHDLMachines","abstract":[],"role":"collection","kind":"symbol","title":"VHDLMachines"},"doc://VHDLMachines/documentation/VHDLMachines/Arrangement/machines":{"title":"machines","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"machines","kind":"identifier"},{"text":": [","kind":"text"},{"text":"MachineInstance","kind":"typeIdentifier","preciseIdentifier":"s:12VHDLMachines15MachineInstanceV"},{"text":" : ","kind":"text"},{"text":"MachineMapping","kind":"typeIdentifier","preciseIdentifier":"s:12VHDLMachines14MachineMappingV"},{"text":"]","kind":"text"}],"type":"topic","url":"\/documentation\/vhdlmachines\/arrangement\/machines","kind":"symbol","role":"symbol","abstract":[{"text":"All machines in the arrangement.","type":"text"}],"identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/Arrangement\/machines"},"doc://VHDLMachines/documentation/VHDLMachines/MachineInstance":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MachineInstance"}],"kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/vhdlmachines\/machineinstance","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/MachineInstance","navigatorTitle":[{"kind":"identifier","text":"MachineInstance"}],"abstract":[{"type":"text","text":"A "},{"code":"MachineInstance","type":"codeVoice"},{"type":"text","text":" represents an instance of a machine that lives within an arrangement. The "},{"code":"name","type":"codeVoice"},{"text":" of","type":"text"},{"text":" ","type":"text"},{"text":"the instance should be unique to any other instance of the same machine. The ","type":"text"},{"code":"type","type":"codeVoice"},{"type":"text","text":" property is the type"},{"type":"text","text":" "},{"type":"text","text":"of the machine, typically derived from a shared path where the machine is located."}],"title":"MachineInstance"},"doc://VHDLMachines/documentation/VHDLMachines/Arrangement":{"url":"\/documentation\/vhdlmachines\/arrangement","type":"topic","identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/Arrangement","abstract":[{"type":"text","text":"An arrangement represents a collection of machines that are executing together. An arrangment has a set of"},{"type":"text","text":" "},{"text":"parent machines which act as entry points into the program. This structure does not infer any execution","type":"text"},{"text":" ","type":"text"},{"text":"order for the machines in this arrangement. Instead, this arrangement simply defines the machines and the","type":"text"},{"text":" ","type":"text"},{"text":"capability of each machine (Suspensible, Parameterised, Custom Ringlets etc).","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Arrangement","kind":"identifier"}],"role":"symbol","kind":"symbol","title":"Arrangement","navigatorTitle":[{"text":"Arrangement","kind":"identifier"}]},"doc://VHDLMachines/documentation/VHDLMachines/MachineMapping":{"navigatorTitle":[{"text":"MachineMapping","kind":"identifier"}],"identifier":"doc:\/\/VHDLMachines\/documentation\/VHDLMachines\/MachineMapping","role":"symbol","url":"\/documentation\/vhdlmachines\/machinemapping","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MachineMapping"}],"abstract":[{"text":"A machine mapping is a mapping of variables to the external interface of the machine. The variables","type":"text"},{"type":"text","text":" "},{"type":"text","text":"must be either clocks, external signals, parameters or return variables."}],"title":"MachineMapping","type":"topic"}}}